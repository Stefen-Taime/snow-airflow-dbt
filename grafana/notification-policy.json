{
    "receiver": "Slack - FinOps Alerts",
    "group_by": ["grafana_folder", "alertname"],
    "group_wait": "30s",
    "group_interval": "5m",
    "repeat_interval": "4h",
    "routes": [
        {
            "receiver": "Slack - FinOps Alerts",
            "object_matchers": [
                ["severity", "=", "critical"]
            ],
            "group_wait": "10s",
            "repeat_interval": "1h",
            "continue": false
        },
        {
            "receiver": "Slack - FinOps Alerts",
            "object_matchers": [
                ["severity", "=", "warning"]
            ],
            "group_wait": "30s",
            "repeat_interval": "4h",
            "continue": false
        },
        {
            "receiver": "Slack - FinOps Alerts",
            "object_matchers": [
                ["severity", "=", "info"]
            ],
            "group_wait": "1m",
            "repeat_interval": "12h",
            "continue": false
        }
    ]
}
